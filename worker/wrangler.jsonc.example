{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cassandra-yt-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-10",
  "compatibility_flags": ["nodejs_compat"],
  "migrations": [
    {
      "new_sqlite_classes": ["CassandraYtMCP"],
      "tag": "v1"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "CassandraYtMCP",
        "name": "MCP_OBJECT"
      }
    ]
  },
  "kv_namespaces": [
    {
      "binding": "OAUTH_KV",
      "id": "<your-kv-namespace-id>"
    }
  ],
  "routes": [
    {
      "pattern": "<subdomain>.<domain>/*",
      "zone_name": "<domain>"
    }
  ],
  "observability": {
    "enabled": true
  },
  "dev": {
    "port": 8790
  }
}
